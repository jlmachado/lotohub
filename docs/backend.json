
{
  "entities": {
    "Banca": {
      "title": "Banca",
      "description": "Entidade Master do Tenant",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "subdomain": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "SUSPENDED"] },
        "saldo": { "type": "number" }
      }
    },
    "User": {
      "title": "User",
      "description": "Usuário isolado por Banca",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "terminal": { "type": "string" },
        "tipoUsuario": { "type": "string" },
        "saldo": { "type": "number" },
        "bancaId": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/bancas/{bancaId}": {
      "schema": "#/backend/entities/Banca",
      "description": "Configurações master da banca"
    },
    "/bancas/{bancaId}/usuarios/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "Usuários exclusivos do tenant"
    },
    "/bancas/{bancaId}/apostas/{apostaId}": {
      "schema": "object",
      "description": "Bilhetes isolados"
    },
    "/bancas/{bancaId}/ledgerEntries/{entryId}": {
      "schema": "object",
      "description": "Extrato financeiro transacional"
    },
    "/jdbResults/{resultId}": {
      "schema": "object",
      "description": "Resultados globais (Shared Data)"
    }
  }
}
