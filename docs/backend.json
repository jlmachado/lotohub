
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Usuário do sistema (Jogador, Promotor, Cambista, Admin)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "terminal": { "type": "string" },
        "email": { "type": "string" },
        "nome": { "type": "string" },
        "tipoUsuario": { "type": "string", "enum": ["USUARIO", "PROMOTOR", "CAMBISTA", "ADMIN", "SUPER_ADMIN"] },
        "saldo": { "type": "number" },
        "bonus": { "type": "number" },
        "bancaId": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Banca": {
      "title": "Banca",
      "description": "Unidade de negócio (Tenant)",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "subdomain": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "LedgerEntry": {
      "title": "LedgerEntry",
      "description": "Registro financeiro no livro razão",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string" },
        "modulo": { "type": "string" }
      }
    },
    "Aposta": {
      "title": "Aposta",
      "description": "Registro de aposta de loteria ou bicho",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "loteria": { "type": "string" },
        "valor": { "type": "string" },
        "status": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "Coleção global de usuários e terminais"
    },
    "/bancas/{bancaId}": {
      "schema": "#/backend/entities/Banca",
      "description": "Configurações de unidades/bancas"
    },
    "/ledgerEntries/{entryId}": {
      "schema": "#/backend/entities/LedgerEntry",
      "description": "Movimentações financeiras para auditoria"
    },
    "/apostas/{apostaId}": {
      "schema": "#/backend/entities/Aposta",
      "description": "Apostas de loterias em aberto e finalizadas"
    },
    "/football_bets/{betId}": {
      "schema": "object",
      "description": "Bilhetes de futebol sportsbook"
    },
    "/snooker_channels/{channelId}": {
      "schema": "object",
      "description": "Canais e mesas de sinuca"
    }
  }
}
