
{
  "entities": {
    "User": {
      "title": "User",
      "description": "Perfil de usuário completo com saldo, bônus e permissões por cargo.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "terminal": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "nome": { "type": "string" },
        "tipoUsuario": { "type": "string", "enum": ["USUARIO", "PROMOTOR", "CAMBISTA", "ADMIN", "SUPER_ADMIN"] },
        "saldo": { "type": "number" },
        "bonus": { "type": "number" },
        "bancaId": { "type": "string" },
        "status": { "type": "string", "enum": ["ACTIVE", "BLOCKED"] }
      },
      "required": ["id", "terminal", "email", "tipoUsuario", "bancaId"]
    },
    "LedgerEntry": {
      "title": "LedgerEntry",
      "description": "Registro imutável de movimentação financeira (Livro Razão).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "bancaId": { "type": "string" },
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "balanceAfter": { "type": "number" },
        "modulo": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ApostaLoteria": {
      "title": "ApostaLoteria",
      "description": "Bilhete de loteria (Bicho, Seninha, etc).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "bancaId": { "type": "string" },
        "loteria": { "type": "string" },
        "valor": { "type": "number" },
        "status": { "type": "string", "enum": ["aguardando", "premiado", "perdeu"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "FootballBet": {
      "title": "FootballBet",
      "description": "Aposta esportiva em futebol.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "bancaId": { "type": "string" },
        "stake": { "type": "number" },
        "potentialWin": { "type": "number" },
        "status": { "type": "string", "enum": ["OPEN", "WON", "LOST", "VOID"] }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "Coleção principal de usuários e administradores."
    },
    "/ledger/{entryId}": {
      "schema": { "$ref": "#/backend/entities/LedgerEntry" },
      "description": "Histórico financeiro global para auditoria e extratos."
    },
    "/bancas/{bancaId}/apostas/{apostaId}": {
      "schema": { "$ref": "#/backend/entities/ApostaLoteria" },
      "description": "Apostas organizadas por banca para facilitar a descarga e conferência."
    },
    "/bancas/{bancaId}/football_bets/{betId}": {
      "schema": { "$ref": "#/backend/entities/FootballBet" },
      "description": "Bilhetes de futebol para processamento automático de resultados."
    }
  }
}
