{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Perfil global do usuário vinculado ao Firebase Auth.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["superadmin", "admin", "promotor", "cambista", "user"] },
        "bancaId": { "type": "string" },
        "saldo": { "type": "number" },
        "bonus": { "type": "number" },
        "status": { "type": "string", "enum": ["ACTIVE", "BLOCKED"] }
      },
      "required": ["id", "uid", "role", "bancaId"]
    },
    "Aposta": {
      "title": "Aposta",
      "description": "Registro de aposta individual.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "bancaId": { "type": "string" },
        "loteria": { "type": "string" },
        "valor": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "userId", "bancaId", "valor"]
    },
    "JdbResult": {
      "title": "JdbResult",
      "description": "Resultados diários do Jogo do Bicho.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "prizes": { "type": "array" }
      },
      "required": ["id", "date", "prizes"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/UserProfile" },
      "description": "Dados privados de cada usuário autenticado."
    },
    "/bancas/{bancaId}/configuracoes/{doc}": {
      "schema": "object",
      "description": "Configurações específicas da banca."
    },
    "/bancas/{bancaId}/jdbResults/{docId}": {
      "schema": { "$ref": "#/backend/entities/JdbResult" },
      "description": "Resultados das extrações para uma banca específica."
    },
    "/bancas/{bancaId}/apostas/{apostaId}": {
      "schema": { "$ref": "#/backend/entities/Aposta" },
      "description": "Livro de apostas registradas na banca."
    }
  }
}