rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regra Global SaaS Multi-Banca
    // Impede que dados vazem entre diferentes bancaId
    // O acesso é permitido apenas se o bancaId no caminho coincidir com o bancaId do token do usuário
    match /bancas/{bancaId}/{document=**} {
      allow read, write: if request.auth != null 
        && (
          request.auth.token.tipoUsuario == 'SUPER_ADMIN' ||
          request.auth.token.bancaId == bancaId
        );
    }
    
    // Coleção de Resultados (Shared Data - Leitura Pública)
    match /jdbResults/{resultId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.tipoUsuario == 'SUPER_ADMIN';
    }
    
    // Configurações públicas do sistema (Banners, Popups ativos)
    match /banners/{bannerId} {
      allow read: if resource.data.active == true;
    }
    match /popups/{popupId} {
      allow read: if resource.data.active == true;
    }
  }
}