rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔍 Funções auxiliares de contexto e segurança
    function isLogged() {
      return request.auth != null && request.auth.uid != null;
    }

    // Verifica se o usuário é SuperAdmin (armazenado na banca mestre)
    function isSuperAdmin() {
      let masterPath = /databases/$(database)/documents/bancas/default/usuarios/$(request.auth.uid);
      return isLogged() && exists(masterPath) && (
        get(masterPath).data.get('role', '') == "superadmin" || 
        get(masterPath).data.get('tipoUsuario', '') == "SUPER_ADMIN"
      );
    }

    // Verifica se o usuário é Admin daquela banca específica
    function isAdmin(bancaId) {
      if (!isLogged()) return false;
      if (isSuperAdmin()) return true;
      let path = /databases/$(database)/documents/bancas/$(bancaId)/usuarios/$(request.auth.uid);
      return exists(path) && (
        get(path).data.get('tipoUsuario', '') == "ADMIN" || 
        get(path).data.get('role', '') == "admin"
      );
    }

    // 👑 Superadmin possui acesso global irrestrito
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // 👤 Perfil Privado do Usuário (Legado/Global)
    match /users/{userId} {
      allow read, write: if isLogged() && (request.auth.uid == userId || isSuperAdmin());
    }

    // 🏪 Estrutura Multi-Tenant Principal
    match /bancas/{bancaId} {
      
      // Permite leitura da banca para resolução de contexto público
      allow read: if true;
      allow write: if isSuperAdmin();

      // 🔓 DADOS PÚBLICOS (Configurações, Resultados, Banners, Notícias, Sorteios)
      // Aberto para leitura por qualquer visitante
      match /configuracoes/{docId} { allow read: if true; allow write: if isAdmin(bancaId); }
      match /banners/{docId} { allow read: if true; allow write: if isAdmin(bancaId); }
      match /popups/{docId} { allow read: if true; allow write: if isAdmin(bancaId); }
      match /news_messages/{docId} { allow read: if true; allow write: if isAdmin(bancaId); }
      match /jdbResults/{docId} { allow read: if true; allow write: if isAdmin(bancaId); }
      match /snooker/{docId} { allow read: if true; allow write: if isAdmin(bancaId); }
      match /bingo_draws/{docId} { allow read: if true; allow write: if isAdmin(bancaId); }
      match /snooker_scoreboards/{docId} { allow read: if true; allow write: if isAdmin(bancaId); }
      match /football_leagues/{id} { allow read: if true; allow write: if isAdmin(bancaId); }
      match /football_matches/{id} { allow read: if true; allow write: if isAdmin(bancaId); }

      // 🔒 DADOS PROTEGIDOS (Apostas, Financeiro, Usuários, Chat)
      
      // Usuários: Dono pode ler/escrever, Admin pode ler/escrever tudo da banca
      match /usuarios/{uid} {
        allow read: if isLogged() && (request.auth.uid == uid || isAdmin(bancaId));
        allow write: if isLogged() && (request.auth.uid == uid || isAdmin(bancaId));
      }

      // Apostas: Dono pode criar e ler suas próprias, Admin pode gerenciar
      match /apostas/{id} {
        allow create: if isLogged();
        allow read: if isLogged() && (isAdmin(bancaId) || (resource != null && resource.data.userId == request.auth.uid));
        allow update, delete: if isAdmin(bancaId);
      }

      match /snooker_bets/{id} {
        allow create: if isLogged();
        allow read: if isLogged() && (isAdmin(bancaId) || (resource != null && resource.data.userId == request.auth.uid));
        allow update, delete: if isAdmin(bancaId);
      }

      match /football_bets/{id} {
        allow create: if isLogged();
        allow read: if isLogged() && (isAdmin(bancaId) || (resource != null && resource.data.userId == request.auth.uid));
        allow update, delete: if isAdmin(bancaId);
      }

      match /bingo_tickets/{id} {
        allow create: if isLogged();
        allow read: if isLogged() && (isAdmin(bancaId) || (resource != null && resource.data.userId == request.auth.uid));
        allow update, delete: if isAdmin(bancaId);
      }

      // Financeiro (Ledger): Dono pode ler os seus, Admin pode ler e escrever
      match /ledgerEntries/{id} {
        allow read: if isLogged() && (isAdmin(bancaId) || (resource != null && resource.data.userId == request.auth.uid));
        allow write: if isAdmin(bancaId);
      }

      // Chat e Social
      match /snooker_chat/{id} {
        allow read: if true;
        allow create: if isLogged();
        allow delete: if isAdmin(bancaId);
      }

      match /snooker_presence/{id} {
        allow read: if true;
        allow write: if isLogged();
      }

      // Logs e Operação
      match /snooker_sync_logs/{id} { allow read, write: if isAdmin(bancaId); }
      match /snooker_cashout_log/{id} { allow read: if isLogged() && (isAdmin(bancaId) || (resource != null && resource.data.userId == request.auth.uid)); allow write: if isLogged(); }
      match /bingo_payouts/{id} { allow read: if isLogged() && (isAdmin(bancaId) || (resource != null && resource.data.userId == request.auth.uid)); allow write: if isAdmin(bancaId); }
    }

    // 🔄 Compatibilidade com Coleções Globais (Legado)
    match /jdbResults/{id} { allow read: if true; allow write: if isSuperAdmin(); }
    match /football_leagues/{id} { allow read: if true; allow write: if isSuperAdmin(); }
    match /apostas/{id} { allow read, write: if isSuperAdmin(); }
    match /ledgerEntries/{id} { allow read, write: if isSuperAdmin(); }
  }
}