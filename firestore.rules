rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * FIRESTORE SECURITY RULES - PROTOTYPING MODE
     * 
     * Core Philosophy:
     * This ruleset implements a robust authorization model centered around user ownership 
     * and terminal-based data segregation. It prioritizes strict access control over who 
     * can view or modify data, while maintaining flexibility on the internal data structure 
     * to support rapid development.
     * 
     * Data Structure:
     * - /users/{userId}: Private user profiles containing sensitive financial balances.
     * - /bancas/{bancaId}: Publicly visible terminal/branch information.
     * - /bancas/{bancaId}/jdbResults/{resultId}: Subcollection for daily lottery outcomes, 
     *   segregated by terminal (Banca) to ensure efficient and secure querying.
     * 
     * Key Security Decisions:
     * - Path-Based Ownership: User data is secured by matching the {userId} in the path 
     *   directly to the authenticated UID.
     * - Relational Integrity: For lottery results, the rules enforce that the `bancaId` 
     *   inside the document matches the parent collection path, preventing data from 
     *   being orphaned or misaligned.
     * - Authenticated Read Access: Lottery results are accessible to all signed-in users 
     *   to allow both customers and administrators to view outcomes as requested.
     * 
     * Denormalization for Authorization:
     * - The `bancaId` is required to be present on every `JdbResult` document. This 
     *   allows for "Authorization Independence," where rules can verify the relationship 
     *   without performing expensive `get()` calls to the parent Banca document.
     */

    // --- Helper Functions ---

    /** @description Checks if the request is from a signed-in user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the document exists and the current user is the owner. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Validates that the bancaId in the document matches the ID in the path. */
    function matchesPathBanca(bancaId) {
      return request.resource.data.bancaId == bancaId;
    }

    /** @description Ensures the bancaId in an existing document matches the path during updates/deletes. */
    function existingMatchesPathBanca(bancaId) {
      return resource.data.bancaId == bancaId;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for individual user profiles and financial balances.
     * @path /users/{userId}
     * @allow (get, list, create, update, delete) if user is the owner of the path.
     * @deny if userId in path does not match request.auth.uid.
     * @principle Enforces strict private data ownership via path-based authorization.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for operational terminals (Bancas).
     * @path /bancas/{bancaId}
     * @allow (get, list) for any authenticated user to facilitate terminal discovery.
     * @deny writes for non-admin users (defaulting to false for safety in this version).
     * @principle Provides public read access for discovery while protecting configuration.
     */
    match /bancas/{bancaId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // TODO: Implement Admin-only write role checks.
    }

    /**
     * @description Rules for the corrected lottery results collection (jdbResults).
     * @path /bancas/{bancaId}/jdbResults/{jdbResultId}
     * @allow (get, list) for all authenticated users to view results as requested.
     * @allow (create, update, delete) for authenticated users, enforcing relational integrity.
     * @deny if the document's bancaId does not match the parent bancaId in the path.
     * @principle Supports QAPs by ensuring collection paths and internal data are aligned.
     */
    match /bancas/{bancaId}/jdbResults/{jdbResultId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && matchesPathBanca(bancaId);
      allow update: if isSignedIn() && resource != null && existingMatchesPathBanca(bancaId);
      allow delete: if isSignedIn() && resource != null && existingMatchesPathBanca(bancaId);
    }
  }
}