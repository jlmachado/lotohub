
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regra específica para perfis de usuário
    match /bancas/{bancaId}/usuarios/{userId} {
      // Permite a criação do próprio documento se autenticado (essencial para o registro)
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Permite leitura e escrita pelo próprio usuário ou superadmins
      allow read, write: if request.auth != null && (
        request.auth.uid == userId || 
        request.auth.token.role == 'superadmin' ||
        request.auth.token.tipoUsuario == 'SUPER_ADMIN'
      );
    }

    // Regra Global SaaS Multi-Banca para outros documentos
    match /bancas/{bancaId}/{document=**} {
      allow read: if request.auth != null; 
      
      allow write: if request.auth != null 
        && (
          request.auth.token.role == 'superadmin' ||
          request.auth.token.tipoUsuario == 'SUPER_ADMIN' ||
          request.auth.token.bancaId == bancaId
        );
    }
    
    // Coleção de Resultados (Shared Data - Leitura Pública)
    match /jdbResults/{resultId} {
      allow read: if true;
      allow write: if request.auth != null && (request.auth.token.role == 'superadmin' || request.auth.token.role == 'admin');
    }
    
    // Configurações públicas do sistema
    match /banners/{bannerId} {
      allow read: if true;
    }
    match /popups/{popupId} {
      allow read: if true;
    }
  }
}
