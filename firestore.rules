
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    // Regra de Ouro: SuperAdmins podem tudo
    function isSuperAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.tipoUsuario == 'SUPER_ADMIN';
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /bancas/{bancaId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /ledgerEntries/{entryId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }

    match /apostas/{apostaId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }

    match /football_bets/{betId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isSuperAdmin();
    }

    match /snooker_channels/{channelId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /{path=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
