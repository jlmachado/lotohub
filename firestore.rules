rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔍 Funções auxiliares
    function isLogged() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isLogged() && getUserData().role == "superadmin";
    }

    function isAdmin(bancaId) {
      return isLogged() && (getUserData().role == "admin" || getUserData().role == "superadmin") && (getUserData().bancaId == bancaId || getUserData().role == "superadmin");
    }

    function belongsToBanca(bancaId) {
      return isLogged() && getUserData().bancaId == bancaId;
    }

    // 👑 Superadmin possui acesso global irrestrito
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // 👤 Perfil do Usuário (Privado)
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // 🏪 Estrutura de Bancas (Isolamento Multi-Tenant)
    match /bancas/{bancaId} {

      // 🔓 DADOS PÚBLICOS (UI e Resultados)
      // Visitantes precisam ler essas informações para renderizar o site
      match /configuracoes/{doc} {
        allow read: if true;
        allow write: if isAdmin(bancaId);
      }

      match /banners/{id} {
        allow read: if true;
        allow write: if isAdmin(bancaId);
      }

      match /popups/{id} {
        allow read: if true;
        allow write: if isAdmin(bancaId);
      }

      match /news_messages/{id} {
        allow read: if true;
        allow write: if isAdmin(bancaId);
      }

      match /jdbResults/{id} {
        allow read: if true;
        allow write: if isAdmin(bancaId);
      }

      match /snooker/{id} {
        allow read: if true;
        allow write: if isAdmin(bancaId);
      }

      match /bingo_draws/{id} {
        allow read: if true;
        allow write: if isAdmin(bancaId);
      }

      // 🎯 APOSTAS (Privado por Usuário/Banca)
      match /apostas/{apostaId} {
        allow create: if isLogged();
        allow read: if isLogged() && (resource == null || resource.data.userId == request.auth.uid || isAdmin(bancaId));
        allow update, delete: if isAdmin(bancaId);
      }

      match /football_bets/{id} {
        allow create: if isLogged();
        allow read: if isLogged() && (resource == null || resource.data.userId == request.auth.uid || isAdmin(bancaId));
        allow update, delete: if isAdmin(bancaId);
      }

      // 👥 USUÁRIOS DA BANCA (Gestão interna)
      match /usuarios/{uid} {
        allow read: if isLogged() && (request.auth.uid == uid || isAdmin(bancaId));
        allow write: if isAdmin(bancaId);
      }

      // 💸 TRANSAÇÕES (Ledger)
      match /ledgerEntries/{id} {
        allow read: if isLogged() && (resource == null || resource.data.userId == request.auth.uid || isAdmin(bancaId));
        allow write: if isAdmin(bancaId);
      }
      
      // 🎱 SNOOKER EXTRAS
      match /snooker_scoreboards/{id} { allow read: if true; allow write: if isAdmin(bancaId); }
      match /snooker_sync_logs/{id} { allow read: if isAdmin(bancaId); allow write: if isAdmin(bancaId); }
    }
  }
}