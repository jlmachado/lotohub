
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Funções auxiliares para validação de segurança
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.tipoUsuario == 'SUPER_ADMIN';
    }

    function matchesBanca(data) {
      return isAuthenticated() && request.auth.token.bancaId == data.bancaId;
    }

    // Regra Global de Isolamento por Banca
    // Aplica-se a todas as coleções que possuem o campo bancaId
    match /{collection}/{docId} {
      // Permissão de leitura: SuperAdmin, Membro da Banca ou Coleções Públicas
      allow read: if 
        isSuperAdmin() || 
        (resource != null && matchesBanca(resource.data)) ||
        // Coleções que precisam ser lidas antes do login ou de forma global
        collection in ['bancas', 'jdbResults', 'news_messages', 'banners', 'popups', 'snooker_channels', 'bingo_draws', 'system_settings'];

      // Permissão de escrita: SuperAdmin ou Membro da Banca validado
      allow write: if 
        isSuperAdmin() || 
        (request.method == 'create' && matchesBanca(request.resource.data)) ||
        (request.method == 'update' && matchesBanca(resource.data)) ||
        (request.method == 'delete' && matchesBanca(resource.data));
    }

    // Regras específicas para a coleção de Usuários (Segurança de Perfil)
    match /users/{userId} {
      allow read, write: if 
        isSuperAdmin() || 
        (isAuthenticated() && request.auth.uid == userId) ||
        (isAuthenticated() && request.auth.token.tipoUsuario == 'ADMIN' && request.auth.token.bancaId == resource.data.bancaId);
    }
  }
}
