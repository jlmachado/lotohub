rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra global para bancas: permite leitura e escrita para qualquer usuário autenticado.
    // Isso garante que o motor de sincronização funcione corretamente para usuários logados.
    match /bancas/{bancaId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    // Permitir leitura pública de resultados se necessário (opcional, mas seguro para este caso)
    match /jdbResults/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

  }
}