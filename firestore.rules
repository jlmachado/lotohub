rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Regra Simplificada para Prototipagem Multi-Banca
     * Permite que qualquer usuário autenticado acesse os dados de sua banca.
     */
    match /bancas/{bancaId}/{document=**} {
      allow read, write: if request.auth != null;
    }

    /**
     * Regras para Perfis de Usuário (Legado/Compatibilidade)
     */
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}