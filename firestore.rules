rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔍 Funções auxiliares seguras
    function isLogged() {
      return request.auth != null && request.auth.uid != null;
    }

    // Busca dados do usuário na banca mestre (default) para validação de cargo
    function getUserData() {
      let path = /databases/$(database)/documents/bancas/default/usuarios/$(request.auth.uid);
      return isLogged() && exists(path) ? get(path).data : {};
    }

    function isSuperAdmin() {
      let data = getUserData();
      return isLogged() && (
        data.get('role', '') == "superadmin" || 
        data.get('tipoUsuario', '') == "SUPER_ADMIN"
      );
    }

    function isAdmin(bancaId) {
      let data = getUserData();
      return isLogged() && (
        data.get('role', '') == "admin" || 
        data.get('role', '') == "superadmin" || 
        data.get('tipoUsuario', '') == "ADMIN" || 
        data.get('tipoUsuario', '') == "SUPER_ADMIN" ||
        (data.get('bancaId', '') == bancaId && data.get('tipoUsuario', '') == "ADMIN")
      );
    }

    // 👑 Superadmin possui acesso global irrestrito
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // 👤 Perfil Privado do Usuário (Sincronizado com Auth)
    match /users/{userId} {
      allow read, write: if isLogged() && (request.auth.uid == userId || isSuperAdmin());
    }

    // 🏪 Estrutura de Bancas (Isolamento Multi-Tenant)
    match /bancas/{bancaId} {

      // 🔓 DADOS PÚBLICOS (Acessíveis mesmo sem login para renderizar a UI)
      match /configuracoes/{docId} {
        allow read: if true;
        allow write: if isAdmin(bancaId);
      }

      match /banners/{docId} {
        allow read: if true;
        allow write: if isAdmin(bancaId);
      }

      match /popups/{docId} {
        allow read: if true;
        allow write: if isAdmin(bancaId);
      }

      match /news_messages/{docId} {
        allow read: if true;
        allow write: if isAdmin(bancaId);
      }

      match /jdbResults/{docId} {
        allow read: if true;
        allow write: if isAdmin(bancaId);
      }

      match /snooker/{docId} {
        allow read: if true;
        allow write: if isAdmin(bancaId);
      }
      
      match /snooker_scoreboards/{docId} {
        allow read: if true;
        allow write: if isAdmin(bancaId);
      }

      match /bingo_draws/{docId} {
        allow read: if true;
        allow write: if isAdmin(bancaId);
      }

      // 🎯 INTERAÇÃO PÚBLICA (Chat)
      match /snooker_chat/{msgId} {
        allow read: if true;
        allow create: if isLogged();
        allow delete: if isAdmin(bancaId);
      }

      // 🔒 DADOS PROTEGIDOS (Requer Login e Vinculação)
      
      match /usuarios/{uid} {
        // Permitir que qualquer usuário logado leia para fins de validação de existência
        // mas a escrita é protegida
        allow read: if isLogged();
        allow write: if isLogged() && (request.auth.uid == uid || isAdmin(bancaId));
      }

      match /apostas/{apostaId} {
        allow create: if isLogged();
        allow read: if isLogged() && (resource == null || resource.data.userId == request.auth.uid || isAdmin(bancaId));
        allow update, delete: if isAdmin(bancaId);
      }

      match /snooker_bets/{betId} {
        allow create: if isLogged();
        allow read: if isLogged() && (resource == null || resource.data.userId == request.auth.uid || isAdmin(bancaId));
        allow update, delete: if isAdmin(bancaId);
      }

      match /ledgerEntries/{id} {
        allow read: if isLogged() && (resource == null || resource.data.userId == request.auth.uid || isAdmin(bancaId));
        allow write: if isAdmin(bancaId);
      }
      
      match /bingo_tickets/{id} {
        allow read: if isLogged() && (resource == null || resource.data.userId == request.auth.uid || isAdmin(bancaId));
        allow create: if isLogged();
      }
    }
  }
}