
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // PERMISSÃO TOTAL PARA FASE DE MIGRAÇÃO
    // Permite leitura e escrita em qualquer documento para garantir que o 
    // espelhamento do LocalStorage funcione sem interrupções.
    match /{path=**} {
      allow read, write: if true;
    }
  }
}
