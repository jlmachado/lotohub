rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Regra Global SaaS: Permite acesso total dentro do caminho da banca para usuários autenticados
    match /bancas/{bancaId}/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Regra para coleções legadas na raiz (se existirem)
    match /jdbResults/{resultId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /popups/{popupId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}