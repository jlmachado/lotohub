rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regra Global SaaS Multi-Banca
    // O acesso é permitido se o usuário for SUPER_ADMIN (acesso global)
    // ou se o bancaId do token coincidir com o bancaId do caminho.
    match /bancas/{bancaId}/{document=**} {
      allow read, write: if request.auth != null 
        && (
          request.auth.token.tipoUsuario == 'SUPER_ADMIN' ||
          request.auth.token.bancaId == bancaId
        );
    }
    
    // Coleção de Resultados (Shared Data - Leitura Pública)
    match /jdbResults/{resultId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.tipoUsuario == 'SUPER_ADMIN';
    }
    
    // Configurações públicas do sistema
    match /banners/{bannerId} {
      allow read: if true;
    }
    match /popups/{popupId} {
      allow read: if true;
    }
  }
}