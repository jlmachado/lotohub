<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    tools:context=".PrinterSettingsActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Impressora Bluetooth Pareada"
        android:textAppearance="?attr/textAppearanceTitleMedium" />

    <Spinner
        android:id="@+id/spinnerPrinters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:minHeight="48dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Largura do Papel"
        android:textAppearance="?attr/textAppearanceTitleMedium" />

    <RadioGroup
        android:id="@+id/radioGroupWidth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/radio48mm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="48mm" />

        <RadioButton
            android:id="@+id/radio58mm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="58mm" />

        <RadioButton
            android:id="@+id/radio80mm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="80mm" />
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Configurações de Fonte"
        android:textAppearance="?attr/textAppearanceTitleMedium" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tamanho da Fonte"
            android:gravity="center_vertical" />

        <Spinner
            android:id="@+id/spinnerFontSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:entries="@array/font_sizes"
            android:minHeight="48dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Espaçamento entre Linhas"
            android:gravity="center_vertical" />

        <Spinner
            android:id="@+id/spinnerLineHeight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:entries="@array/line_heights"
            android:minHeight="48dp" />
    </LinearLayout>


    <View
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btnTestPrint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Testar Impressão"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Salvar Configurações" />

</LinearLayout>
